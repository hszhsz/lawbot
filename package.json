{
  "name": "lawbot",
  "version": "0.1.0",
  "description": "Professional Chinese legal AI agent - TUI application",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "lawbot": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "law",
    "legal",
    "ai",
    "tui",
    "china"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "drizzle-orm": "^0.40.0",
    "ink": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "react": "^18.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.0",
    "@types/react": "^18.3.0",
    "drizzle-kit": "^0.30.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
